<!DOCTYPE html>
<html>
<head>
<title>Tamilnadu Tourism</title>

<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background-color: #f5f5f5;
    padding-top:70px;
}

/* NAVBAR */
nav {
    background-color: purple;
    width: 100%;
    padding: 20px 0;
    text-align: center;
    position:fixed;
    z-index:10000;
    top:0;
    left:0;
    right:0;
    display:block;
}

nav a {
    color: white;
    margin: 0 20px;
    text-decoration: none;
    font-size: 18px;
    font-weight: bold;
    display:inline-block;
}

nav a:hover {
    color: yellow;
}

/* HERO / HEADER */
.hero {
    background: linear-gradient(to right, purple, darkviolet);
    color: white;
    text-align: center;
    padding: 60px 20px;
    width:100%;
}

.hero h1 {
    font-size: 40px;
}

.hero p {
    font-size: 20px;
}

/* SECTION */
.section {
    padding: 30px;
    text-align: center;
}

/* WHY CHOOSE US */
.check-list {
    max-width: 500px;
    margin: 0 auto;
    text-align: left;
}

.check-list p::before {
    content: "✔ ";
    color: green;
}

/* VIDEO */
.video-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    margin: 40px 0;
}

iframe {
    border-radius: 15px;
    box-shadow: 0px 4px 10px gray;
    max-width: 90%;
}

/* LOGIN FORM */
.login-box {
    width: 350px;
    margin: 30px auto;
    padding: 20px;
    background: white;
    border-radius: 15px;
    box-shadow: 0px 4px 10px gray;
}

.login-box h2 {
    text-align: center;
    color: purple;
}

.login-box input {
    width: 90%;
    padding: 10px;
    margin: 10px 0;
    border-radius: 10px;
    border: 1px solid gray;
}

.login-box button {
    width: 100%;
    padding: 10px;
    background-color: purple;
    color: white;
    border: none;
    border-radius: 20px;
    cursor: pointer;
    font-size: 16px;
}

.login-box button:hover {
    background-color: darkviolet;
}

/* FOOTER */
footer {
    background-color: purple;
    color: white;
    text-align: center;
    padding: 15px;
}
</style>

</head>
<body>

<nav>
    <a href="#">Home</a>
    <a href="#">Places</a>
    <a href="#">Hotels</a>
    <a href="#">Feast</a>
</nav>

<div class="hero">
    <h1>Explore Tamilnadu</h1>
    <p>Discover Culture, Temples, Beaches & Hill Stations</p>
</div>

<div class="section">
    <h2>About Tamilnadu Tourism</h2>
    <p>
        Tamilnadu is a land of ancient temples, beautiful beaches, 
        peaceful hill stations, and rich cultural heritage.
        Plan your perfect trip with us!
    </p>
</div>

<div class="section">
    <h2>Why Choose Us?</h2>
    <div class="check-list">
        <p>Affordable hotel bookings</p>
        <p>Best tourist guidance</p>
        <p>Easy travel planning</p>
        <p>Friendly support during your trip</p>
    </div>
</div>

<div class="video-container">
    <h2>Watch Tamilnadu</h2>
    <iframe width="800" height="450" src="https://www.youtube.com/embed/vFQyLgCiWE8" title="Explore Tamil Nadu" frameborder="0" allowfullscreen></iframe>
</div>

<div class="section">
    <div class="login-box">
        <h2>Login / Register</h2>
        <form onsubmit="return validateLogin()">
            <input type="text" placeholder="Full Name" required>
            <input type="email" id="userEmail" placeholder="Email" required>
            <input type="tel" placeholder="Phone Number">
            <input type="password" id="userPass" placeholder="Password" required>
            <button type="submit">Submit</button>
        </form>
    </div>
</div>

<footer>
    <p>&copy; 2026 Tamilnadu Tourism | All Rights Reserved</p>
</footer>

<script>
    function validateLogin() {
        // 1. Get the values from the email and password boxes
        var email = document.getElementById("userEmail").value;
        var pass = document.getElementById("userPass").value;

        // 2. Set the "Correct" answers
        var correctEmail = "admin@tourism.com";
        var correctPass = "Tamil123";

        // 3. Logic: Check Email first, then Password
        if (email !== correctEmail) {
            alert("❌ Incorrect Email! Please check your email address.");
            return false; // Stops the page from refreshing
        } 
        
        if (pass !== correctPass) {
            alert("❌ Incorrect Password! Access Denied.");
            return false; // Stops the page from refreshing
        }

        // If everything is correct
        alert("✅ Welcome to Tamilnadu Tourism! Login Successful.");
        return true; 
    }
</script>

</body>
</html>
